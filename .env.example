DOCUMENT_CORE_DATA_DIR=/data
DOCUMENT_CORE_DATABASE_URL=postgresql+psycopg://documentcore:documentcore@postgres:5432/documentcore
DOCUMENT_CORE_DATABASE_AUTO_CREATE=false
DOCUMENT_CORE_HOTFOLDER_INTERVAL=2
DOCUMENT_CORE_WORKER_POLL_INTERVAL=1
DOCUMENT_CORE_WORKER_LEASE_SECONDS=300
DOCUMENT_CORE_WORKER_MAX_ATTEMPTS=3
DOCUMENT_CORE_WORKER_RETRY_BASE_SECONDS=5
DOCUMENT_CORE_CONNECTOR=filesystem
DOCUMENT_CORE_REQUIRE_ROUTING_REFERENCE=false
DOCUMENT_CORE_TESSERACT_LANG=deu+eng
DOCUMENT_CORE_INGEST_CHUNK_SIZE_BYTES=1048576
DOCUMENT_CORE_MAX_FILE_SIZE_BYTES=26214400
DOCUMENT_CORE_MAX_PDF_PAGES=100
DOCUMENT_CORE_MAX_IMAGE_PIXELS=40000000
DOCUMENT_CORE_OCR_TIMEOUT_SECONDS=60
DOCUMENT_CORE_MALWARE_SCANNER=disabled
DOCUMENT_CORE_CLAMAV_HOST=clamav
DOCUMENT_CORE_CLAMAV_PORT=3310
DOCUMENT_CORE_MALWARE_SCAN_TIMEOUT_SECONDS=30
DOCUMENT_CORE_AUTH_ENABLED=true
DOCUMENT_CORE_BOOTSTRAP_ADMIN_USERNAME=admin
DOCUMENT_CORE_BOOTSTRAP_ADMIN_PASSWORD=change-this-before-production
DOCUMENT_CORE_SESSION_TTL_HOURS=12
